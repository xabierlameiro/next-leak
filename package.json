{
  "name": "next-leak",
  "version": "0.1.0",
  "description": "Find out whether your Next.js app actually leaks memory \u2014 how much, on which route, and whose fault it is.",
  "keywords": [
    "nextjs",
    "memory-leak",
    "heap-snapshot",
    "diagnostics",
    "cli"
  ],
  "license": "MIT",
  "author": "Xabier Lameiro <xabier.lameiro@gmail.com>",
  "type": "module",
  "bin": {
    "next-leak": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "pack:smoke": "node scripts/pack-smoke.mjs",
    "test:mutation": "stryker run",
    "prepare": "husky >/dev/null 2>&1 || true",
    "release": "release-it"
  },
  "pnpm": {
    "overrides": {
      "uuid": ">=11.1.1"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@memlab/core": "^2.0.4",
    "@memlab/heap-analysis": "^2.0.4",
    "@release-it/conventional-changelog": "^11.0.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/autocannon": "^7.12.7",
    "@types/node": "^26.1.1",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.1.10",
    "husky": "^9.1.7",
    "release-it": "^20.2.1",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "autocannon": "^8.0.0",
    "semver": "^7.8.5",
    "zod": "^4.4.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xabierlameiro/next-leak.git"
  },
  "homepage": "https://github.com/xabierlameiro/next-leak#readme",
  "bugs": {
    "url": "https://github.com/xabierlameiro/next-leak/issues"
  }
}
